{
  "name": "sentinel-os",
  "private": true,
  "version": "2.5.0",
  "description": "Industrial-grade Technical Intelligence Dashboard for Staff+ Engineer Preparation",
  "author": "Sundeep",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sundeepg98/Sentinel-OS.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "dotenv -e server/.env -- node server/index.js",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "clean": "rimraf dist playwright-report test-results bundle-analysis.html",
    "build": "npm run clean && tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "preview": "vite preview",
    "test:server": "NODE_OPTIONS='--experimental-vm-modules' npx jest server/tests",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' npx jest server/tests --coverage --coverageThreshold='{\"global\":{\"branches\":80,\"functions\":80,\"lines\":80,\"statements\":80}}'",
    "test:e2e": "playwright test",
    "test": "npm run test:server && npm run test:e2e",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "tsc-files --noEmit"
    ],
    "server/**/*.js": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.3",
    "@clerk/clerk-sdk-node": "^4.13.23",
    "@google/generative-ai": "^0.24.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.21",
    "3d-force-graph": "^1.79.1",
    "axios": "^1.13.6",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "crypto-js": "^4.2.0",
    "d3-force": "^3.0.0",
    "d3-force-3d": "^3.0.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "flexsearch": "^0.8.212",
    "framer-motion": "^12.34.4",
    "gray-matter": "^4.0.3",
    "helmet": "^8.1.0",
    "lucide-react": "^0.576.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "natural": "^8.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postprocessing": "^6.38.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-force-graph-2d": "^1.29.1",
    "react-force-graph-3d": "^1.29.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sqlite-vec": "^0.1.7-alpha.2",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "three-spritetext": "^1.10.0",
    "three-stdlib": "^2.36.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.50.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.4.3",
    "npm-check-updates": "^19.6.3",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tailwindcss": "^4.2.1",
    "tsc-files": "^1.1.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
