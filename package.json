{
  "name": "sentinel-os",
  "private": true,
  "version": "2.6.0",
  "description": "Industrial-grade Technical Intelligence Dashboard for Staff+ Engineer Preparation",
  "author": "Sundeep",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sundeepg98/Sentinel-OS.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "dotenv -e .env.local -- node server/index.js",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:windows": "powershell -Command \"Get-NetTCPConnection -LocalPort 5173,3002 -ErrorAction SilentlyContinue | Where-Object { $_.OwningProcess -gt 4 } | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force }\" ; npm run dev",
    "clean": "rimraf --glob dist playwright-report test-results bundle-analysis.html \"server/logs/*.json\"",
    "build": "npm run clean && tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "preview": "vite preview",
    "test:server": "cross-env NODE_OPTIONS='--experimental-vm-modules' npx jest server/tests",
    "test:coverage:server": "cross-env NODE_OPTIONS='--experimental-vm-modules' npx jest server/tests --coverage",
    "test:frontend": "vitest run",
    "test:frontend:ui": "vitest",
    "test:coverage:frontend": "vitest run --coverage",
    "test:coverage": "npm run test:coverage:server && npm run test:coverage:frontend",
    "test:e2e": "playwright test",
    "test": "npm run test:server && npm run test:frontend && npm run test:e2e",
    "verify": "node scripts/verify-environments.js",
    "backup": "node scripts/backup-db.js",
    "bundle-guard": "node scripts/bundle-guard.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix",
      "vitest run --related --passWithNoTests",
      "tsc-files --noEmit"
    ],
    "server/**/*.js": [
      "prettier --write",
      "eslint --fix",
      "jest --findRelatedTests --passWithNoTests"
    ]
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.3",
    "@clerk/clerk-sdk-node": "^5.1.6",
    "@google/generative-ai": "^0.24.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.21",
    "3d-force-graph": "^1.79.1",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cross-env": "^10.1.0",
    "d3-force": "^3.0.0",
    "d3-force-3d": "^3.0.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "flexsearch": "^0.8.212",
    "framer-motion": "^12.34.4",
    "gray-matter": "^4.0.3",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "lru-cache": "^9.1.2",
    "lucide-react": "^0.576.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "p-limit": "^7.3.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postprocessing": "^6.38.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-force-graph-2d": "^1.29.1",
    "react-force-graph-3d": "^1.29.1",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sqlite-vec": "^0.1.7-alpha.2",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "three-spritetext": "^1.10.0",
    "three-stdlib": "^2.36.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.50.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jsdom": "^28.1.0",
    "lint-staged": "^15.4.3",
    "npm-check-updates": "^19.6.3",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tailwindcss": "^4.2.1",
    "tsc-files": "^1.1.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  }
}
