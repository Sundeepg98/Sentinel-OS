{
  "name": "sentinel-os",
  "private": true,
  "version": "2.8.0",
  "description": "Industrial-grade Technical Intelligence Dashboard for Staff+ Engineer Preparation",
  "author": "Sundeep",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Sundeepg98/Sentinel-OS.git"
  },
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "dotenv -e .env.local -- node server/index.js",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:windows": "powershell -Command \"Get-NetTCPConnection -LocalPort 5173,3002 -ErrorAction SilentlyContinue | Where-Object { $_.OwningProcess -gt 4 } | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force }\" ; npm run dev",
    "clean": "rimraf --glob dist playwright-report test-results bundle-analysis.html \"server/logs/*.json\"",
    "build": "npm run clean && tsc -b && vite build && npm run bundle-guard",
    "lint": "eslint .",
    "format": "prettier --write .",
    "preview": "vite preview",
    "test:server": "cross-env NODE_OPTIONS='--experimental-vm-modules' npx jest server/tests",
    "test:coverage:server": "cross-env NODE_OPTIONS='--experimental-vm-modules' npx jest server/tests --coverage",
    "test:frontend": "vitest run",
    "test:frontend:ui": "vitest",
    "test:coverage:frontend": "vitest run --coverage",
    "test:coverage": "npm run test:coverage:server && npm run test:coverage:frontend",
    "test:e2e": "playwright test",
    "test": "npm run test:server && npm run test:frontend && npm run test:e2e",
    "verify": "node scripts/verify-environments.js",
    "backup": "node scripts/backup-db.js",
    "restore": "node scripts/restore-db.js",
    "bundle-guard": "node scripts/bundle-guard.cjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix",
      "vitest related --passWithNoTests --run",
      "tsc-files --noEmit"
    ],
    "server/**/*.js": [
      "prettier --write",
      "eslint --fix",
      "cross-env NODE_OPTIONS='--experimental-vm-modules' jest --findRelatedTests --passWithNoTests"
    ]
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.3",
    "@clerk/clerk-sdk-node": "^5.1.6",
    "@google/generative-ai": "^0.24.1",
    "@tanstack/react-query": "^5.67.2",
    "better-sqlite3": "^11.10.0",
    "clsx": "^2.1.1",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "flexsearch": "^0.8.212",
    "framer-motion": "^12.34.4",
    "gray-matter": "^4.0.3",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "lru-cache": "^9.1.2",
    "lucide-react": "^0.479.0",
    "multer": "^1.4.5-lts.1",
    "p-limit": "^6.3.0",
    "pg": "^8.13.3",
    "pgvector": "^0.2.0",
    "pino": "^9.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-force-graph-3d": "^1.25.1",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sqlite-vec": "^0.1.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tailwind-merge": "^3.0.2",
    "three": "^0.174.0",
    "three-spritetext": "^1.9.4",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^9.22.0",
    "@playwright/test": "^1.51.0",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/three": "^0.174.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.4.3",
    "npm-check-updates": "^17.1.15",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "rollup-plugin-visualizer": "^11.1.0",
    "tsc-files": "^1.1.4",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.26.0",
    "vite": "^6.2.1",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^3.0.8"
  }
}
