# 🔐 Sentinel-OS Configuration

# --- TECHNICAL CORE ---
GEMINI_API_KEY="AIzaSy..." # Get from https://aistudio.google.com/
DATABASE_URL="postgres://..." # For Cloud Persistence (PostgreSQL)
NODE_ENV="development"     # development | staging | production
PORT=3002

# --- VERIFICATION CLUSTER ---
LOCAL_API_URL="http://localhost:3002"
STAGING_API_URL="https://sentinel-os-staging.onrender.com"
PRODUCTION_API_URL="https://sentinel-os-bcsv.onrender.com"

# --- AUTHENTICATION (CLERK) ---
# Set to 'false' to bypass login during local development
VITE_AUTH_ENABLED="false"
AUTH_ENABLED="false"

# Clerk Keys (Get from https://dashboard.clerk.com/)
VITE_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Developer Bypass (Only works if enabled in auth.js)
DEV_BYPASS_TOKEN="sentinel_staff_2026"

# --- LOGGING ---
LOG_LEVEL="info"

# --- NETWORK ---
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS="http://localhost:5173,https://sentinel-os-staging.onrender.com,https://sentinel-os-bcsv.onrender.com"
